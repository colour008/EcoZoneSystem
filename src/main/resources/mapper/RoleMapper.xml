<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zone.mapper.RoleMapper">

    <!--    数据库字段列表-->
    <sql id="Base_Column_List">
        id, role_name, role_code, role_sort, create_time, update_time
    </sql>

    <!-- ResultMap -->
    <resultMap id="RoleResultMap" type="com.zone.entity.sys.Role">
        <id column="id" property="id"/>
        <result column="role_name" property="roleName"/>
        <result column="role_code" property="roleCode"/>
        <result column="role_sort" property="roleSort"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!--    添加角色-->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into sys_role(role_name, role_code, role_sort, create_time, update_time)
        values(#{roleName}, #{roleCode}, #{roleSort}, NOW(), NOW())
    </insert>

    <!--    查询角色编码-->
    <select id="selectByRoleCode" resultMap="RoleResultMap">
        select * from sys_role where role_code = #{roleCode}
    </select>

    <!--    分页查询角色-->
    <select id="getRolePage" resultMap="RoleResultMap">
        select
        <include refid="Base_Column_List"/>
        from sys_role
        <where>
            <if test="roleName != null and roleName != ''">
                AND role_name like concat('%', #{roleName}, '%')
            </if>
            <if test="roleCode != null and roleCode != ''">
                AND role_code like concat('%', #{roleCode}, '%')
            </if>
        </where>
        ORDER BY role_sort ASC, id ASC
    </select>

    <!--    修改角色-->
    <update id="update">
        update sys_role
        <set>
            <if test="roleName != null">
                role_name = #{roleName},
            </if>
            <if test="roleCode != null">
                role_code = #{roleCode},
            </if>
            <if test="roleSort != null">
                role_sort = #{roleSort},
            </if>
            update_time = NOW()
        </set>
        where id = #{id}
    </update>

    <!--    根据ID查询角色-->
    <select id="selectById" resultMap="RoleResultMap">
        select
        <include refid="Base_Column_List"/>
        from sys_role
        where id = #{id}
    </select>

    <!-- 修改时：查询角色编码是否被其他角色占用 -->
    <select id="selectByRoleCodeExcludeId" resultMap="RoleResultMap">
        select
        <include refid="Base_Column_List"/>
        from sys_role
        where role_code = #{roleCode}
        and id != #{id}  <!-- 关键：排除自身ID -->
    </select>

    <!-- 删除角色时：查询角色下是否有用户 -->
    <select id="countUserRoleByRoleIds" resultType="int">
        select count(1) from sys_user_role
        where role_id in
        <foreach collection="roleIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 删除角色 -->
    <delete id="deleteByIds">
        delete from sys_role where id in
        <foreach collection="roleIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 根据用户ID查询角色编码 -->
    <select id="getRoleCodesByUserId" resultType="string">
        select r.role_code
        from sys_role r
        left join sys_user_role ur on r.id = ur.role_id
        where ur.user_id = #{id}
    </select>

    <!-- 查询所有激活的角色 -->
    <select id="selectAllActiveRoles" resultMap="RoleResultMap">
        SELECT id, role_name, role_sort
        FROM sys_role
        ORDER BY role_sort ASC
    </select>

    <!-- 删除角色菜单关联关系 -->
    <delete id="deleteRoleMenusByRoleId">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>

    <!-- 批量插入角色菜单关联关系 -->
    <insert id="insertRoleMenus">
        INSERT INTO sys_role_menu (role_id, menu_id) VALUES
        <foreach collection="menuIds" item="menuId" separator=",">
            (#{roleId}, #{menuId})
        </foreach>
    </insert>

</mapper>