<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zone.mapper.UserMapper">

    <!-- ResultMap -->
    <resultMap id="UserResultMap" type="com.zone.entity.sys.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="avatar" property="avatar"/>
        <result column="real_name" property="realName"/>
        <result column="phone" property="phone"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据用户名查询用户 -->
    <select id="selectByUsername" resultMap="UserResultMap">
        select
            id,
            username,
            password,
            avatar,
            real_name,
            phone,
            status
        from sys_user
        where username = #{username}
    </select>
<!--    返回用户列表-->
    <select id="getUserlist" resultMap="UserResultMap">
        select
            id,
            username,
            password,
            avatar,
            real_name,
            phone,
            status,
            create_time,
            update_time
        from sys_user
    </select>
<!--    分页查询用户列表-->
    <select id="getUserPage" resultMap="UserResultMap">
        select
        id,
        username,
        password,
        avatar,
        real_name,
        phone,
        status,
        create_time,
        update_time
        from sys_user
        <where>
            <if test="username != null and username != ''">
                AND username like concat('%',#{username},'%')
            </if>
            <if test="realName != null and realName != ''">
                AND real_name like concat('%',#{realName},'%')
            </if>
            <if test="phone != null and phone != ''">
                AND phone like concat('%',#{phone},'%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY id
    </select>

    <insert id="insert">
        insert into sys_user(username,password,avatar,real_name,phone,status,create_time,update_time)
        values(#{username},#{password},#{avatar},#{realName},#{phone},#{status},NOW(),NOW())
    </insert>

</mapper>